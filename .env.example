# =============================================================================
# InsightSphere - Root Environment Variables
# =============================================================================
# This file contains all environment variables used across all services.
# For service-specific files, see:
#   - api/.env.example
#   - frontend/.env.example
#   - doc-parser/.env.example
# =============================================================================

# =============================================================================
# API SERVICE (Deno)
# =============================================================================

# Server
PORT=8000
NODE_ENV=development

# Supabase (Required)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# SUPABASE_STORAGE_BUCKET=anotherbrainfileplayground

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your-qdrant-api-key-here
# QDRANT_COLLECTION=insightsphere-documents

# OpenAI (Required)
OPENAI_API_KEY=sk-your-openai-api-key-here

# HuggingFace (Optional)
# HUGGINGFACE_API_KEY=hf_your-huggingface-api-key-here

# Document Parser Service
DOC_PARSER_URL=http://localhost:8080

# Authentication
LEGACY_JWT_SECRET=your-jwt-secret-here

# CORS
# FRONTEND_URL=https://your-frontend-domain.com

# =============================================================================
# FRONTEND SERVICE (SvelteKit/Vite)
# =============================================================================

# Supabase (Required - use ANON key, not service role)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# API
VITE_API_URL=http://localhost:8000/v1

# =============================================================================
# DOCUMENT PARSER SERVICE (Go)
# =============================================================================

# Server (defaults to 8080)
# GO_PORT=8080
GIN_MODE=debug
