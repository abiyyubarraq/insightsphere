# =============================================================================
# InsightSphere API - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=8000
NODE_ENV=development
# ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Supabase Configuration (Required)
# -----------------------------------------------------------------------------
# Get these from your Supabase project settings: https://supabase.com/dashboard
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Storage bucket name (optional - defaults to "anotherbrainfileplayground")
# SUPABASE_STORAGE_BUCKET=anotherbrainfileplayground

# -----------------------------------------------------------------------------
# Qdrant Vector Database Configuration
# -----------------------------------------------------------------------------
# Local development
QDRANT_URL=http://localhost:6333

# For Qdrant Cloud (optional - not needed for local development)
# QDRANT_API_KEY=your-qdrant-api-key-here

# Collection name (optional - defaults to "insightsphere-documents")
# QDRANT_COLLECTION=insightsphere-documents

# -----------------------------------------------------------------------------
# OpenAI Configuration (Required for embeddings and chat)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here

# -----------------------------------------------------------------------------
# HuggingFace Configuration (Optional - for development/fallback)
# -----------------------------------------------------------------------------
# HUGGINGFACE_API_KEY=hf_your-huggingface-api-key-here

# -----------------------------------------------------------------------------
# Document Parser Service
# -----------------------------------------------------------------------------
# URL of the Go OCR parser service
DOC_PARSER_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Legacy JWT secret for token verification
LEGACY_JWT_SECRET=your-jwt-secret-here

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Frontend URL for CORS (production)
# FRONTEND_URL=https://your-frontend-domain.com

# API base URL (used in test dashboard)
# API_BASE_URL=http://localhost:8000
