# =============================================================================
# InsightSphere Document Parser (Go) - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Port to run the parser service on (default: 8080)
PORT=8080

# Gin framework mode: "debug" or "release"
# Set to "release" in production for better performance
GIN_MODE=debug
