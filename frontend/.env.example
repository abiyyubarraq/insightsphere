# =============================================================================
# InsightSphere Frontend - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# Note: All variables must be prefixed with VITE_ to be exposed to the client
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration (Required)
# -----------------------------------------------------------------------------
# Get these from your Supabase project settings: https://supabase.com/dashboard
# Use the ANON (public) key here, NOT the service role key
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# URL of the Deno API server
VITE_API_URL=http://localhost:8000/v1
